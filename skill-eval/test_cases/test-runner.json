{
  "skill_name": "test-runner",
  "rubrics": ["phase_completion", "instruction_adherence"],
  "test_cases": [
    {
      "id": 1,
      "prompt": "I made changes to 3 Python files. Run the test suite to check for regressions.",
      "expected_behaviors": ["Uses pytest for test execution", "Runs tests sequentially"],
      "assertions": ["contains: pytest", "contains: sequential"]
    },
    {
      "id": 2,
      "prompt": "The last test run had 4 failures. How do I re-run just the failing tests efficiently?",
      "expected_behaviors": ["Recommends --lf flag for last-failed", "Explains targeted re-run strategy"],
      "assertions": ["contains: --lf", "contains: fail"]
    },
    {
      "id": 3,
      "prompt": "Before I commit, run both pre-commit checks and the pytest test suite.",
      "expected_behaviors": ["Runs pre-commit before pytest", "Covers both linting and testing"],
      "assertions": ["contains: pre-commit", "contains: pytest"]
    }
  ]
}
